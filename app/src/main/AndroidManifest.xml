        <provider android:name=".stub.StubProvider_P0" android:authorities="${applicationId}.vcp.p0" android:exported="false" android:process=":p0" />
        <provider android:name=".stub.StubProvider_P1" android:authorities="${applicationId}.vcp.p1" android:exported="false" android:process=":p1" />
        <provider android:name=".stub.StubProvider_P2" android:authorities="${applicationId}.vcp.p2" android:exported="false" android:process=":p2" />
        <provider android:name=".stub.StubProvider_P3" android:authorities="${applicationId}.vcp.p3" android:exported="false" android:process=":p3" />
        <provider android:name=".stub.StubProvider_P4" android:authorities="${applicationId}.vcp.p4" android:exported="false" android:process=":p4" />
