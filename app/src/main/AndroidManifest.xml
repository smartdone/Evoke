        <activity android:name=".stub.StubActivity_P8_A0" android:exported="false" android:process=":p8" />
        <activity android:name=".stub.StubActivity_P8_A1" android:exported="false" android:process=":p8" />
        <activity android:name=".stub.StubActivity_P9_A0" android:exported="false" android:process=":p9" />
        <activity android:name=".stub.StubActivity_P9_A1" android:exported="false" android:process=":p9" />

        <service android:name=".stub.StubService_P0" android:exported="false" android:process=":p0" />
        <service android:name=".stub.StubService_P1" android:exported="false" android:process=":p1" />
        <service android:name=".stub.StubService_P2" android:exported="false" android:process=":p2" />
        <service android:name=".stub.StubService_P3" android:exported="false" android:process=":p3" />
        <service android:name=".stub.StubService_P4" android:exported="false" android:process=":p4" />
        <service android:name=".stub.StubService_P5" android:exported="false" android:process=":p5" />
        <service android:name=".stub.StubService_P6" android:exported="false" android:process=":p6" />
